# =============================================================================
# Next Chapter Travel — Environment Variables
# Copy to .env and fill in values. Required vars are marked [REQUIRED].
# =============================================================================

# ── Database ───────────────────────────────────────────────────────────────
# [REQUIRED] MySQL connection string (PlanetScale, TiDB, etc.)
DATABASE_URL=mysql://user:password@host:3306/dbname

# ── Auth / Session ─────────────────────────────────────────────────────────
# [REQUIRED] Secret for signing JWT session cookies
JWT_SECRET=

# [REQUIRED] Manus OAuth project ID
VITE_APP_ID=

# [REQUIRED] Manus OAuth portal URL for login redirect
VITE_OAUTH_PORTAL_URL=https://auth.manus.im

# Manus OAuth server URL (default shown)
OAUTH_SERVER_URL=https://api.manus.im

# [REQUIRED] Owner's Manus open_id (grants admin role)
OWNER_OPEN_ID=

# ── Forge / AI ─────────────────────────────────────────────────────────────
# Built-in Forge API for AI features (LLM, image gen, etc.)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────
# API key for sending invite emails
RESEND_API_KEY=

# ── Storage (S3-compatible) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ── Metrics ────────────────────────────────────────────────────────────────
# Optional token to protect /api/metrics and /api/metrics/prom
METRICS_TOKEN=

# ── Analytics (Umami) ──────────────────────────────────────────────────────
# If set, loads the Umami script dynamically on client
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Netlify Deploy Hook ────────────────────────────────────────────────────
# Build hook URL to trigger Netlify deploys programmatically
# (Get from Netlify → Site → Build & deploy → Build hooks → Add build hook)
NETLIFY_BUILD_HOOK=
