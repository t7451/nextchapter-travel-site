# nextchapter-travel-site — environment variables
# Copy to .env and fill in real values
# NEVER commit the actual .env file

# Frontend (Vite)
VITE_APP_ID=nextchapter
VITE_OAUTH_PORTAL_URL=https://auth.your-domain.com
VITE_FRONTEND_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://forge.api.url

# Server / API
DATABASE_URL=mysql://user:password@host:3306/dbname
JWT_SECRET=change_me
OAUTH_SERVER_URL=https://auth.your-domain.com
OWNER_OPEN_ID=jessica@example.com
BUILT_IN_FORGE_API_URL=https://forge.api.url
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Integrations (optional)
RESEND_API_KEY=
METRICS_TOKEN=
